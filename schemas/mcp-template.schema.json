{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://de-skills/schemas/mcp-template.schema.json",
  "type": "object",
  "required": [
    "name",
    "description",
    "transport",
    "metadata"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "transport": {
      "type": "object",
      "required": [
        "type",
        "command",
        "args",
        "env"
      ],
      "properties": {
        "type": {
          "const": "stdio"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array"
        },
        "env": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": [
        "validation",
        "best_for"
      ],
      "properties": {
        "validation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "best_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
