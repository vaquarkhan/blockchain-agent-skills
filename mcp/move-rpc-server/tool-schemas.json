{
  "tools": [
    {
      "name": "sui_getObject",
      "description": "Read Sui object by ID.",
      "inputSchema": {
        "type": "object",
        "required": ["object_id"],
        "properties": {"object_id": {"type": "string"}}
      }
    },
    {
      "name": "aptos_view",
      "description": "Call Aptos view function.",
      "inputSchema": {
