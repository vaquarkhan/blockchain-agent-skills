{
  "name": "bitcoin-rpc",
  "description": "Bitcoin Core JSON-RPC for chain info and transaction lookup.",
  "transport": {
    "type": "stdio",
    "command": "python",
    "args": ["mcp/bitcoin-rpc-server/server.py"],
    "env": {
      "BITCOIN_RPC_URL": "${BITCOIN_RPC_URL}",
      "LND_REST_URL": "${LND_REST_URL}",
      "LND_MACAROON": "${LND_MACAROON}"
    }
  },
  "metadata": {
    "chains": ["bitcoin", "lightning"],
    "validation": ["python scripts/validate-mcp-servers.py"],
    "best_for": ["getblockchaininfo", "getrawtransaction", "lightning_getinfo", "lightning_decodepay"]
  }
}
