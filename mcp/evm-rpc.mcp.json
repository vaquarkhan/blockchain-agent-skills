{
  "name": "evm-rpc",
  "description": "Read-only EVM RPC access for simulate-first transaction planning across Ethereum, Arbitrum, Base, and Polygon.",
  "transport": {
    "type": "stdio",
    "command": "python",
    "args": ["mcp/evm-rpc-server/server.py"],
    "env": {
      "ALCHEMY_ETH_URL": "${ALCHEMY_ETH_URL}",
      "ALCHEMY_ARB_URL": "${ALCHEMY_ARB_URL}",
      "ALCHEMY_BASE_URL": "${ALCHEMY_BASE_URL}",
      "ALCHEMY_POLYGON_URL": "${ALCHEMY_POLYGON_URL}"
    }
  },
  "metadata": {
    "chains": ["ethereum", "arbitrum", "base", "polygon"],
    "validation": [
      "curl -s ${ALCHEMY_ETH_URL} -X POST -H 'Content-Type: application/json' -d '{\"jsonrpc\":\"2.0\",\"method\":\"eth_blockNumber\",\"params\":[],\"id\":1}'"
    ],
    "best_for": [
      "eth_call simulation",
      "block and receipt queries",
      "gas estimation",
      "contract read calls"
    ]
  }
}
